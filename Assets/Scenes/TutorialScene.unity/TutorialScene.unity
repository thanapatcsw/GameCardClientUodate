  m_Script: {fileID: 11500000, guid: 2dfb2e8b83b4d4c4fa773c19a3e235f8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::TutorialUI
  customFont: {fileID: 11400000, guid: 6600443213e56b947a8932c9b87493ac, type: 2}
  mainMenuSceneName: MainMenu 1
  slides:
  - title: "[ \u0E01\u0E32\u0E23\u0E40\u0E25\u0E48\u0E19\u0E43\u0E19\u0E41\u0E15\u0E48\u0E25\u0E30\u0E40\u0E17\u0E34\u0E23\u0E4C\u0E19
      ]"
    body: "    \u0E40\u0E21\u0E37\u0E48\u0E2D\u0E16\u0E36\u0E07\u0E40\u0E17\u0E34\u0E23\u0E4C\u0E19\u0E02\u0E2D\u0E07\u0E04\u0E38\u0E13
      \u0E43\u0E2B\u0E49\u0E40\u0E25\u0E37\u0E2D\u0E01\u0E17\u0E33\u0E41\u0E2D\u0E04\u0E0A\u0E31\u0E48\u0E19
      <b>\u0E40\u0E1E\u0E35\u0E22\u0E07 1 \u0E2D\u0E22\u0E48\u0E32\u0E07</b> \u0E04\u0E37\u0E2D
      <b>\u0E2B\u0E22\u0E34\u0E1A\u0E40\u0E2B\u0E23\u0E35\u0E22\u0E0D\u0E17\u0E23\u0E31\u0E1E\u0E22\u0E32\u0E01\u0E23</b>
      (\u0E2B\u0E22\u0E34\u0E1A 3 \u0E2A\u0E35\u0E15\u0E48\u0E32\u0E07\u0E01\u0E31\u0E19
      \u0E2B\u0E23\u0E37\u0E2D 2 \u0E2A\u0E35\u0E40\u0E14\u0E35\u0E22\u0E27\u0E01\u0E31\u0E19),
      \u0E08\u0E48\u0E32\u0E22\u0E17\u0E23\u0E31\u0E1E\u0E22\u0E32\u0E01\u0E23\u0E40\u0E1E\u0E37\u0E48\u0E2D
      <b>\u0E0B\u0E37\u0E49\u0E2D\u0E01\u0E32\u0E23\u0E4C\u0E14</b> \u0E2A\u0E30\u0E2A\u0E21\u0E04\u0E30\u0E41\u0E19\u0E19\u0E0A\u0E31\u0E22\u0E0A\u0E19\u0E30\u0E41\u0E25\u0E30\u0E23\u0E31\u0E1A\u0E2A\u0E48\u0E27\u0E19\u0E25\u0E14
      \u0E2B\u0E23\u0E37\u0E2D\u0E40\u0E25\u0E37\u0E2D\u0E01 <b>\u0E08\u0E2D\u0E07\u0E01\u0E32\u0E23\u0E4C\u0E14</b>
      \u0E17\u0E35\u0E48\u0E40\u0E25\u0E47\u0E07\u0E44\u0E27\u0E49\u0E02\u0E36\u0E49\u0E19\u0E21\u0E37\u0E2D\u0E40\u0E1E\u0E37\u0E48\u0E2D\u0E1B\u0E49\u0E2D\u0E07\u0E01\u0E31\u0E19\u0E04\u0E19\u0E2D\u0E37\u0E48\u0E19\u0E41\u0E22\u0E48\u0E07\u0E41\u0E25\u0E30\u0E40\u0E01\u0E47\u0E1A\u0E44\u0E27\u0E49\u0E0B\u0E37\u0E49\u0E2D\u0E43\u0E19\u0E15\u0E32\u0E16\u0E31\u0E14\u0E44\u0E1B\r\n\u0E1C\u0E39\u0E49\u0E40\u0E25\u0E48\u0E19\u0E17\u0E35\u0E48\u0E2A\u0E32\u0E21\u0E32\u0E23\u0E16\u0E2A\u0E30\u0E2A\u0E21\u0E04\u0E30\u0E41\u0E19\u0E19\u0E44\u0E14\u0E49\u0E04\u0E23\u0E1A
      20 \u0E04\u0E30\u0E41\u0E19\u0E19\u0E08\u0E30\u0E40\u0E1B\u0E47\u0E19\u0E1C\u0E39\u0E49\u0E0A\u0E19\u0E30"
    icon: ACTION
    illustrationSprite: {fileID: -6300058993222212358, guid: f499cd102bba18d4bb8ed29144964c22, type: 3}
    accentColor: {r: 0.2, g: 0.85, b: 0.4, a: 1}
  - title: "[ \u0E01\u0E32\u0E23\u0E08\u0E2D\u0E07\u0E01\u0E32\u0E23\u0E4C\u0E14
      & \u0E40\u0E2B\u0E23\u0E35\u0E22\u0E0D\u0E14\u0E33 ]"
    body: "    \u0E2B\u0E32\u0E01\u0E04\u0E38\u0E13\u0E15\u0E49\u0E2D\u0E07\u0E01\u0E32\u0E23\u0E08\u0E2D\u0E07\u0E01\u0E32\u0E23\u0E4C\u0E14
      \u0E2A\u0E32\u0E21\u0E32\u0E23\u0E16\u0E17\u0E33\u0E44\u0E14\u0E49\u0E07\u0E48\u0E32\u0E22\u0E46
      \u0E14\u0E49\u0E27\u0E22\u0E01\u0E32\u0E23 <b>\u0E01\u0E14\u0E04\u0E49\u0E32\u0E07\u0E17\u0E35\u0E48\u0E01\u0E32\u0E23\u0E4C\u0E14\u0E40\u0E1B\u0E49\u0E32\u0E2B\u0E21\u0E32\u0E22</b>
      \u0E40\u0E21\u0E37\u0E48\u0E2D\u0E08\u0E2D\u0E07\u0E2A\u0E33\u0E40\u0E23\u0E47\u0E08\u0E04\u0E38\u0E13\u0E08\u0E30\u0E44\u0E14\u0E49\u0E23\u0E31\u0E1A
      <b>\u0E40\u0E2B\u0E23\u0E35\u0E22\u0E0D\u0E14\u0E33 (Black Coin) 1 \u0E40\u0E2B\u0E23\u0E35\u0E22\u0E0D</b>
      \u0E17\u0E31\u0E19\u0E17\u0E35 \u0E0B\u0E36\u0E48\u0E07\u0E40\u0E2B\u0E23\u0E35\u0E22\u0E0D\u0E19\u0E35\u0E49\u0E21\u0E35\u0E04\u0E27\u0E32\u0E21\u0E1E\u0E34\u0E40\u0E28\u0E29\u0E21\u0E32\u0E01\u0E40\u0E1E\u0E23\u0E32\u0E30\u0E04\u0E38\u0E13\u0E2A\u0E32\u0E21\u0E32\u0E23\u0E16\u0E19\u0E33\u0E44\u0E1B\u0E43\u0E0A\u0E49
      <b>\u0E41\u0E17\u0E19\u0E40\u0E2B\u0E23\u0E35\u0E22\u0E0D\u0E2A\u0E35\u0E43\u0E14\u0E01\u0E47\u0E44\u0E14\u0E49\n1
      \u0E40\u0E2B\u0E23\u0E35\u0E22\u0E0D</b> \u0E40\u0E21\u0E37\u0E48\u0E2D\u0E15\u0E49\u0E2D\u0E07\u0E08\u0E48\u0E32\u0E22\u0E17\u0E23\u0E31\u0E1E\u0E22\u0E32\u0E01\u0E23\u0E40\u0E1E\u0E37\u0E48\u0E2D\u0E0B\u0E37\u0E49\u0E2D\u0E01\u0E32\u0E23\u0E4C\u0E14!\r\n"
    icon: COIN
    illustrationSprite: {fileID: -7277918859039230421, guid: d30547528664cbf42af728f538601060, type: 3}
    accentColor: {r: 0.8, g: 0.8, b: 0.8, a: 1}
  - title: "[ \u0E01\u0E32\u0E23\u0E15\u0E2D\u0E1A\u0E04\u0E33\u0E16\u0E32\u0E21
      (Quiz) ]"
    body: "    \u0E40\u0E01\u0E21\u0E19\u0E35\u0E49\u0E44\u0E21\u0E48\u0E44\u0E14\u0E49\u0E27\u0E31\u0E14\u0E41\u0E04\u0E48\u0E14\u0E27\u0E07!
      <b>\u0E17\u0E38\u0E01\u0E46 5 \u0E40\u0E17\u0E34\u0E23\u0E4C\u0E19</b> \u0E23\u0E30\u0E1A\u0E1A\u0E08\u0E30\u0E40\u0E02\u0E49\u0E32\u0E2A\u0E39\u0E48\u0E0A\u0E48\u0E27\u0E07\u0E40\u0E27\u0E25\u0E32\u0E15\u0E2D\u0E1A\u0E04\u0E33\u0E16\u0E32\u0E21
      \u0E1C\u0E39\u0E49\u0E40\u0E25\u0E48\u0E19\u0E17\u0E38\u0E01\u0E04\u0E19\u0E08\u0E30\u0E15\u0E49\u0E2D\u0E07\u0E41\u0E02\u0E48\u0E07\u0E01\u0E31\u0E19\u0E15\u0E2D\u0E1A\u0E04\u0E33\u0E16\u0E32\u0E21\u0E43\u0E2B\u0E49\u0E16\u0E39\u0E01\u0E41\u0E25\u0E30\u0E40\u0E23\u0E47\u0E27\u0E17\u0E35\u0E48\u0E2A\u0E38\u0E14
      \u0E42\u0E14\u0E22\u0E04\u0E27\u0E32\u0E21\u0E44\u0E27\u0E41\u0E25\u0E30\u0E04\u0E27\u0E32\u0E21\u0E16\u0E39\u0E01\u0E15\u0E49\u0E2D\u0E07\u0E19\u0E35\u0E49
      <b>\u0E08\u0E30\u0E21\u0E35\u0E1C\u0E25\u0E42\u0E14\u0E22\u0E15\u0E23\u0E07\u0E15\u0E48\u0E2D\u0E25\u0E33\u0E14\u0E31\u0E1A\u0E01\u0E32\u0E23\u0E40\u0E25\u0E48\u0E19</b>
      \u0E1C\u0E39\u0E49\u0E17\u0E35\u0E48\u0E17\u0E33\u0E44\u0E14\u0E49\u0E14\u0E35\u0E17\u0E35\u0E48\u0E2A\u0E38\u0E14\u0E08\u0E30\u0E44\u0E14\u0E49\u0E23\u0E31\u0E1A\u0E2A\u0E34\u0E17\u0E18\u0E34\u0E4C\u0E43\u0E2B\u0E49\u0E40\u0E23\u0E34\u0E48\u0E21\u0E40\u0E25\u0E48\u0E19\u0E40\u0E1B\u0E47\u0E19\u0E04\u0E19\u0E41\u0E23\u0E01\u0E43\u0E19\u0E23\u0E2D\u0E1A\u0E16\u0E31\u0E14\u0E44\u0E1B\u0E40\u0E1E\u0E37\u0E48\u0E2D\u0E0A\u0E34\u0E07\u0E04\u0E27\u0E32\u0E21\u0E44\u0E14\u0E49\u0E40\u0E1B\u0E23\u0E35\u0E22\u0E1A!\r\n"
    icon: QUIZ
    illustrationSprite: {fileID: -7099968570101673532, guid: 173cb107d6d4df24e8267bca23d56ccd, type: 3}
    accentColor: {r: 0.9, g: 0.4, b: 0.8, a: 1}
